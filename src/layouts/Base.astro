---
import "../styles/global.css";
import { site } from "../site";
import Schema from "../components/Schema.astro";

const b = site.brand;
const fam = (n: string) => n.split(",")[0]!.trim().replace(/\s+/g, "+");
const fontsHref =
  `https://fonts.googleapis.com/css2?family=${fam(b.fonts.display)}:ital@0;1` +
  `&family=${fam(b.fonts.body)}:wght@300;400;500;600;700` +
  (b.fonts.mono ? `&family=${fam(b.fonts.mono)}` : "") +
  `&display=swap`;

const vars =
  `--ink:${b.colors.textPrimary};--ink-soft:${b.colors.textPrimary}c9;--muted:${b.colors.textMuted || "#6f6f76"};` +
  `--paper:${b.colors.background};--paper-2:#FBFAF8;--card:#FFFFFF;` +
  `--blue:${b.colors.primary};--green:${b.colors.accent || b.colors.primary};--gold:${b.colors.secondary || b.colors.accent || b.colors.primary};` +
  `--line:rgba(29,29,31,.10);--line-2:rgba(29,29,31,.06);` +
  `--display:'${b.fonts.display}',Georgia,serif;--sans:'${b.fonts.body}',system-ui,sans-serif;--mono:'${b.fonts.mono || "ui-monospace"}',monospace;`;

const title = `${site.identity.name} — ${site.identity.headline}`;
const desc = site.seo?.description || site.identity.headline;
const base = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = site.seo?.ogImage ? new URL(site.seo.ogImage, base).href : undefined;
---

<!doctype html>
<html lang="en" style={vars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsHref} rel="stylesheet" />
    <Schema />
  </head>
  <body>
    <div class="aurora"><i class="a"></i><i class="b"></i><i class="c"></i></div>
    <slot />
    <script is:inline>
      (function () {
        var reduce = matchMedia("(prefers-reduced-motion:reduce)").matches;
        var nav = document.querySelector("nav");
        addEventListener("scroll", function () { if (nav) nav.classList.toggle("scrolled", scrollY > 20); }, { passive: true });
        var io = new IntersectionObserver(function (es) {
          es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
        }, { threshold: 0.16 });
        document.querySelectorAll(".reveal").forEach(function (el) { io.observe(el); });

        var thread = document.getElementById("thread");
        if (!thread) return;
        var input = document.querySelector(".ask-input");
        var sendBtn = document.querySelector(".chat-input .send");
        var history = [];
        var busy = false;

        function sc() { thread.scrollTop = thread.scrollHeight; }
        function bubble(cls, text) { var d = document.createElement("div"); d.className = "msg " + cls; d.textContent = text; thread.appendChild(d); sc(); return d; }
        function typingDots() { var d = document.createElement("div"); d.className = "msg bot"; d.innerHTML = '<span class="typing"><i></i><i></i><i></i></span>'; thread.appendChild(d); sc(); return d; }
        // textContent typewriter — never parses HTML, so visitor/LLM text can't inject.
        function typeOut(node, text) {
          if (reduce) { node.textContent = text; return; }
          var i = 0, cur = document.createElement("span"); cur.className = "cursor";
          node.textContent = ""; node.appendChild(cur);
          (function step() {
            i++; node.textContent = text.slice(0, i); node.appendChild(cur); sc();
            if (i < text.length) setTimeout(step, 12 + Math.random() * 18); else node.textContent = text;
          })();
        }

        function ask(q) {
          if (busy || !q) return;
          busy = true;
          bubble("user", q);
          history.push({ role: "user", text: q });
          var t = typingDots();
          fetch("/api/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ question: q, history: history.slice(0, -1) }) })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              t.remove();
              var answer = data && data.answer ? data.answer : "I'm having trouble answering right now. Leave your email below and I'll follow up.";
              typeOut(bubble("bot", ""), answer);
              history.push({ role: "model", text: answer });
            })
            .catch(function () { t.remove(); bubble("bot", "I'm having trouble right now — leave your email below and I'll follow up."); })
            .then(function () { busy = false; });
        }

        document.querySelectorAll(".chip").forEach(function (c) { c.addEventListener("click", function () { ask((c.textContent || "").trim()); }); });
        document.querySelectorAll(".tcard").forEach(function (c) {
          c.addEventListener("click", function () {
            var a = document.getElementById("ask"); if (a) a.scrollIntoView({ behavior: "smooth", block: "center" });
            ask((c.getAttribute("data-q") || "").trim());
          });
        });
        function submit() { var v = input ? input.value.trim() : ""; if (v) { input.value = ""; ask(v); } }
        if (input) input.addEventListener("keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); submit(); } });
        if (sendBtn) sendBtn.addEventListener("click", submit);

        setTimeout(function () { bubble("bot", "Hi — ask me anything, or tap a question below."); }, 400);
      })();
    </script>
  </body>
</html>
